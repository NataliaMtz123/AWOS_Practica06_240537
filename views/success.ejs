<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Mercado Pago</title>
    <link href="/css/output.css" rel="stylesheet">
</head>
<body class="font-sans antialiased min-h-screen bg-gradient-to-br from-green-50 to-emerald-50">
    <%- include('partials/header') %>

    <main class="pt-32 pb-20">
        <div class="container mx-auto px-6 max-w-2xl text-center">
            <div class="card">
                <div class="bg-green-100 w-24 h-24 rounded-full flex items-center justify-center mx-auto mb-6">
                    <span class="text-5xl">✅</span>
                </div>
                <h1 class="text-3xl font-bold text-green-600 mb-4">¡Pago Exitoso!</h1>
                <p class="text-gray-600 mb-8">Tu pago ha sido procesado correctamente.</p>
                <a href="/" class="inline-block btn-primary">
                    Volver al inicio
                </a>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>