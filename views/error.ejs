<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Proyecto 3 APIs</title>
    <link href="/css/output.css" rel="stylesheet">
</head>
<body class="font-sans antialiased min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">
    <%- include('partials/header') %>

    <main class="pt-32 pb-20">
        <div class="container mx-auto px-6 text-center">
            <div class="card max-w-md mx-auto">
                <div class="text-6xl mb-4">
                    <% if (title === 'Página no encontrada') { %>
                        🔍
                    <% } else { %>
                        ⚠️
                    <% } %>
                </div>
                <h1 class="text-2xl font-bold text-gray-800 mb-4"><%= title %></h1>
                <p class="text-gray-600 mb-6"><%= message %></p>
                <a href="/" class="btn-primary inline-block">Volver al inicio</a>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>