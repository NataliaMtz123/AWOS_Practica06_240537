<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Mercado Pago</title>
    <link href="/css/output.css" rel="stylesheet">
    <script src="https://sdk.mercadopago.com/js/v2"></script>
</head>
<body class="font-sans antialiased min-h-screen bg-gradient-to-br from-blue-50 to-indigo-50">
    <%- include('partials/header') %>

    <main class="pt-32 pb-20">
        <div class="container mx-auto px-6 max-w-2xl">
            <div class="card">
                <h1 class="text-3xl font-bold text-azul-mercado mb-8">Pagar con Mercado Pago</h1>

                <form id="payment-form" class="space-y-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Email</label>
                        <input type="email" id="email" value="test@test.com" 
                               class="w-full border border-gray-300 rounded-xl p-3 focus:ring-2 focus:ring-azul-mercado focus:border-transparent">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Descripción</label>
                        <input type="text" id="description" value="Producto de prueba" 
                               class="w-full border border-gray-300 rounded-xl p-3 focus:ring-2 focus:ring-azul-mercado focus:border-transparent">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Monto (R$)</label>
                        <input type="number" id="amount" value="1.00" step="0.01" 
                               class="w-full border border-gray-300 rounded-xl p-3 focus:ring-2 focus:ring-azul-mercado focus:border-transparent">
                    </div>

                    <button type="submit" class="w-full btn-primary">
                        Generar PIX
                    </button>
                </form>

                <div id="qr-container" class="mt-8 hidden">
                    <h2 class="text-xl font-semibold mb-4">Escanea el código PIX</h2>
                    <div id="qr-code" class="flex justify-center"></div>
                    <div id="qr-text" class="mt-4 p-4 bg-gray-50 rounded-xl">
                        <p class="text-sm text-gray-600 break-all" id="pix-code"></p>
                    </div>
                    <button id="copy-pix" class="mt-4 px-4 py-2 bg-gray-200 rounded-lg hover:bg-gray-300 transition">
                        Copiar código PIX
                    </button>
                </div>

                <div id="loading" class="hidden text-center py-8">
                    <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-azul-mercado"></div>
                    <p class="mt-2 text-gray-600">Procesando pago...</p>
                </div>
            </div>
        </div>
    </main>

   <script>
    const form = document.getElementById('payment-form');
    const loading = document.getElementById('loading');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        loading.classList.remove('hidden');

        try {
            const response = await fetch('/crear-pago', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    transaction_amount: document.getElementById('amount').value,
                    description: document.getElementById('description').value,
                    email: document.getElementById('email').value
                })
            });

            const data = await response.json();

            if (data.success) {
                // Redirigir al checkout de Mercado Pago
                window.location.href = data.paymentLink;
            } else {
                throw new Error(data.error || 'Error al procesar el pago');
            }
        } catch (error) {
            loading.classList.add('hidden');
            alert('Error: ' + error.message);
        }
    });
</script>

    <%- include('partials/footer') %>
</body>
</html>